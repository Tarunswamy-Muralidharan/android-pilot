{
  "name": "android-pilot",
  "version": "1.0.0",
  "type": "module",
  "description": "The ultimate Android testing MCP server. ADB-direct, Compose-native, token-aware.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "android-pilot": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "android",
    "adb",
    "testing",
    "jetpack-compose",
    "model-context-protocol"
  ],
  "author": "Tarunswamy Muralidharan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tarunswamy-Muralidharan/android-pilot.git"
  },
  "dependencies": {
    "fastmcp": "^3.35.0",
    "fast-xml-parser": "^4.5.0",
    "sharp": "^0.33.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "@types/node": "^22.0.0"
  }
}
